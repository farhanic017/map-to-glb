{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Map to GLB",
    "version": "3.2.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": { "all": false, "open": true },
      "dialog": { "all": true },
      "fs": { "all": false, "readFile": true, "writeFile": true },
      "path": { "all": true }
    },
    "bundle": {
      "active": true,
      "category": "DeveloperTool",
      "copyright": "GPL 3.0 License",
      "deb": {
        "depends": []
      },
      "externalBin": [],
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "identifier": "com.mapglb.app",
      "longDescription": "Map to GLB - Generate real-world 3D maps as GLB files using OpenStreetMap data",
      "macOS": {
        "entitlements": null,
        "exceptionDomain": "",
        "frameworks": [],
        "providerShortName": null,
        "signingIdentity": null
      },
      "resources": [],
      "shortDescription": "3D Building Mapping Service",
      "targets": "all",
      "windows": {
        "certificateThumbprint": null,
        "digestAlgorithm": "sha256",
        "timestampUrl": "",
        "nsis": {
          "installerIcon": "icons/icon.ico",
          "sidebarImage": "icons/sidebar.bmp",
          "headerImage": "icons/header.bmp"
        }
      }
    },
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://* http://*; img-src 'self' https://* http://* data:; style-src 'self' 'unsafe-inline' https://*; font-src 'self' https://*; script-src 'self' 'unsafe-inline'; frame-src 'none'"
    },
    "updater": {
      "active": false
    },
    "windows": [
      {
        "fullscreen": false,
        "height": 900,
        "resizable": true,
        "title": "Map to GLB - 3D Building Mapping",
        "width": 1400,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ]
  }
}
